{
	"name": "omp-comment-checker",
	"version": "0.2.0",
	"description": "Comment checker hook extension for oh-my-pi (omp). Runs @code-yeongyu/comment-checker after write, edit, multiedit, apply_patch, hashline, patch, and replace, then self-heals via omp's session_compact + TUI notifications.",
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/niklasschaeffer/omp-comment-checker",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/niklasschaeffer/omp-comment-checker.git",
		"directory": "."
	},
	"bugs": {
		"url": "https://github.com/niklasschaeffer/omp-comment-checker/issues"
	},
	"keywords": [
		"oh-my-pi",
		"omp",
		"pi",
		"pi-mono",
		"pi-coding-agent",
		"pi-extension",
		"coding-agent",
		"comment-checker",
		"comments",
		"hooks",
		"self-heal",
		"typescript"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"files": [
		"src",
		"LICENSE",
		"NOTICE",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"test": "vitest --run",
		"test:watch": "vitest",
		"typecheck": "tsgo --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "tsgo --noEmit && biome check ."
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*",
		"@oh-my-pi/pi-coding-agent": "*"
	},
	"peerDependenciesMeta": {
		"@mariozechner/pi-ai": { "optional": true },
		"@mariozechner/pi-coding-agent": { "optional": true },
		"@mariozechner/pi-tui": { "optional": true },
		"@oh-my-pi/pi-coding-agent": { "optional": true }
	},
	"dependencies": {
		"@code-yeongyu/comment-checker": "^0.8.0"
	},
	"devDependencies": {
		"@mariozechner/pi-ai": "*",
		"@types/node": "^25.9.1",
		"@biomejs/biome": "2.5.0",
		"@typescript/native-preview": "^7.0.0-dev.20260604.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
